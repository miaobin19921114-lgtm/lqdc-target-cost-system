{
  "name": "lqdc-target-cost-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "railway:start": "prisma db push --accept-data-loss && npm run db:ensure:foundation && npm run db:ensure:buildings && npm run db:ensure:product-types-extra && npm run db:ensure:cost-extra && npm run db:ensure:measure-rules-extra && npm run db:ensure:price-indicators-extra && npm run db:ensure:revenue-tax-extra && npm run db:ensure:procurement-contract-extra && npm run db:ensure:dc-extra && npm run db:ensure:financial-extra && npm run db:ensure:ai-extra && npm run db:seed && npm run db:seed:product-types && npm run db:seed:cost-subjects && npm run db:ensure:cost-calculation-rules && npm run db:ensure:cost-calculation-rule-tax-fields && npm run db:normalize:land-subject-names && npm run db:ensure:rule-template-center && npm run db:ensure:v60-residential-subject-tree && npm run db:ensure:residential-template-high-precision-fields && npm run db:ensure:leaf-rule-calculation-details && npm run db:ensure:l1-l5-precision-rules && npm run db:ensure:template-field-definitions && npm run db:ensure:project-rule-snapshots && npm run db:ensure:version-rule-snapshots && npm run db:ensure:rule-governance && npm run db:ensure:detail-calculation-results && npm run db:seed:project-metrics && npm run db:seed:measure-rules && npm run db:seed:price-indicators && npm run db:sync:metric-values && npm run db:sync:v60-land && next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "next lint",
    "test": "vitest run",
    "db:migrate": "prisma migrate dev",
    "db:ensure:foundation": "tsx prisma/ensure-database-foundation.ts",
    "db:ensure:buildings": "tsx prisma/ensure-project-buildings.ts",
    "db:ensure:product-types-extra": "tsx prisma/ensure-product-type-extra-fields.ts",
    "db:ensure:cost-extra": "tsx prisma/ensure-cost-extra-fields.ts",
    "db:ensure:measure-rules-extra": "tsx prisma/ensure-measure-rule-extra-fields.ts",
    "db:ensure:price-indicators-extra": "tsx prisma/ensure-price-indicator-extra-fields.ts",
    "db:ensure:revenue-tax-extra": "tsx prisma/ensure-revenue-tax-extra-fields.ts",
    "db:ensure:procurement-contract-extra": "tsx prisma/ensure-procurement-contract-extra-fields.ts",
    "db:ensure:dc-extra": "tsx prisma/ensure-dynamic-cost-extra-fields.ts",
    "db:ensure:financial-extra": "tsx prisma/ensure-financial-extra-fields.ts",
    "db:ensure:ai-extra": "tsx prisma/ensure-ai-knowledge-extra-fields.ts",
    "db:ensure:cost-calculation-rules": "tsx prisma/ensure-cost-calculation-rules.ts",
    "db:ensure:cost-calculation-rule-tax-fields": "tsx prisma/ensure-cost-calculation-rule-tax-fields.ts",
    "db:normalize:land-subject-names": "tsx prisma/normalize-land-cost-subject-names.ts",
    "db:ensure:rule-template-center": "tsx prisma/ensure-rule-template-center.ts",
    "db:ensure:v60-residential-subject-tree": "tsx prisma/ensure-v60-residential-subject-tree.ts",
    "db:ensure:residential-template-high-precision-fields": "tsx prisma/ensure-residential-template-high-precision-fields.ts",
    "db:ensure:leaf-rule-calculation-details": "tsx prisma/ensure-leaf-rule-calculation-details.ts",
    "db:ensure:l1-l5-precision-rules": "tsx prisma/ensure-l1-l5-precision-rules.ts",
    "db:ensure:template-field-definitions": "tsx prisma/ensure-template-field-definitions.ts",
    "db:ensure:project-rule-snapshots": "tsx prisma/ensure-project-rule-snapshots.ts",
    "db:ensure:version-rule-snapshots": "tsx prisma/ensure-version-rule-snapshots.ts",
    "db:ensure:rule-governance": "tsx prisma/ensure-rule-governance.ts",
    "db:ensure:detail-calculation-results": "tsx prisma/ensure-detail-calculation-results.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:product-types": "tsx prisma/seed-product-types.ts",
    "db:seed:cost-subjects": "tsx prisma/seed-cost-subjects.ts",
    "db:seed:project-metrics": "tsx prisma/seed-project-metrics.ts",
    "db:seed:measure-rules": "tsx prisma/seed-measure-basis-rules.ts",
    "db:seed:price-indicators": "tsx prisma/seed-price-indicators.ts",
    "db:sync:metric-values": "tsx prisma/sync-project-metric-values.ts",
    "db:sync:v60-land": "tsx prisma/sync-v60-land-subjects.ts",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "docker:start": "sh scripts/docker-start.sh"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "2.4.3",
    "browserslist": "4.24.4",
    "exceljs": "4.4.0",
    "next": "14.2.35",
    "prisma": "5.22.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/node": "20.17.10",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  },
  "engines": {
    "node": "20.x"
  }
}
