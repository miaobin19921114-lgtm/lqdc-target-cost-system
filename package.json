{
  "name": "lqdc-target-cost-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "railway:start": "prisma db push --accept-data-loss && npm run db:seed && npm run db:seed:project-metrics && npm run db:sync:v60-land && next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "next lint",
    "test": "vitest run",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:project-metrics": "tsx prisma/seed-project-metrics.ts",
    "db:sync:v60-land": "tsx prisma/sync-v60-land-subjects.ts",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "docker:start": "sh scripts/docker-start.sh"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "exceljs": "^4.4.0",
    "next": "^14.2.23",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": "20.x"
  }
}
