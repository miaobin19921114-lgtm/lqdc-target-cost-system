generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  editor
  viewer
}

enum VersionStatus {
  draft
  locked
  final
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  role         UserRole @default(admin)
  templates    Template[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

model Template {
  id                String             @id @default(cuid())
  ownerId           String?
  owner             User?              @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  baseTemplateId    String?
  sourceProjectId   String?
  sourceProjectName String?
  name              String
  type              String             @default("住宅开发")
  description       String?
  isDefault         Boolean            @default(false)
  isActive          Boolean            @default(true)
  sortOrder         Int                @default(0)
  products          TemplateProduct[]
  costRules         TemplateCostRule[]
  taxRules          TemplateTaxRule[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now()) @updatedAt

  @@index([ownerId])
  @@index([baseTemplateId])
  @@index([sourceProjectId])
}

model TemplateProduct {
  id                   String   @id @default(cuid())
  templateId            String
  template              Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  category              String
  name                  String
  isSaleable            Boolean  @default(true)
  participateAllocation Boolean  @default(true)
  allocationWeight      Decimal  @default(1)
  sortOrder             Int      @default(0)
  remark                String?
  isActive              Boolean  @default(true)
  disabledAt            DateTime?

  @@unique([templateId, name])
  @@index([templateId])
  @@index([templateId, isActive])
}

model TemplateCostRule {
  id               String   @id @default(cuid())
  templateId       String
  template         Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  costCode         String?
  category         String?
  subjectName      String
  sourceTable      String?
  measureBasis     String?
  unit             String?
  defaultTaxRate   Decimal  @default(0.09)
  allocationMethod String?
  sortOrder        Int      @default(0)
  remark           String?

  @@index([templateId])
}

model TemplateTaxRule {
  id         String   @id @default(cuid())
  templateId String
  template  Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name      String
  rate      Decimal  @default(0)
  scope     String?
  remark    String?
  sortOrder Int      @default(0)

  @@index([templateId])
}

model ProductTypePreset {
  id                      String        @id @default(cuid())
  key                     String        @unique
  name                    String
  category                String
  isSaleable              Boolean       @default(true)
  participateAllocation   Boolean       @default(true)
  defaultVatRate          Decimal       @default(0.09)
  defaultAllocationMethod String        @default("按建筑面积占比")
  defaultIncomeType       String        @default("销售收入")
  description             String?
  enabled                 Boolean       @default(true)
  sortOrder               Int           @default(0)
  projectProducts         ProductType[]
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @default(now()) @updatedAt

  @@index([category])
  @@index([enabled])
}

model Project {
  id                              String   @id @default(cuid())
  activeVersionId                 String?
  sourceTemplateId                String?
  sourceTemplateName              String?
  sourceTemplateType              String?
  name                            String
  city                            String?
  district                        String?
  landArea                        Decimal  @default(0)
  landAreaMu                      Decimal  @default(0)
  redLineArea                     Decimal  @default(0)
  plotRatio                       Decimal  @default(0)
  totalBuildingArea               Decimal  @default(0)
  capacityBuildingArea            Decimal  @default(0)
  aboveGroundArea                 Decimal  @default(0)
  undergroundArea                 Decimal  @default(0)
  saleableArea                    Decimal  @default(0)
  nonSaleableArea                 Decimal  @default(0)
  parkingCount                    Int      @default(0)
  undergroundPropertyParkingCount Int      @default(0)
  undergroundUseRightParkingCount Int      @default(0)
  civilDefenseParkingCount        Int      @default(0)
  aboveGroundParkingCount         Int      @default(0)
  chargingPileCount               Int      @default(0)
  fastChargingPileCount           Int      @default(0)
  slowChargingPileCount           Int      @default(0)
  reservedChargingPileCount       Int      @default(0)
  chargingPileRatio               Decimal  @default(0)
  parkingPowerCapacity            Decimal  @default(0)
  chargingIncludedInParkingPrice  Boolean  @default(false)
  chargingSeparateCostMeasure     Boolean  @default(true)
  parkingRemark                   String?
  buildingCount                   Int      @default(0)
  unitCount                       Int      @default(0)
  householdCount                  Int      @default(0)
  elevatorCount                   Int      @default(0)
  basementFloors                  Int      @default(0)
  aboveGroundFloors               Int      @default(0)
  standardFloorHeight             Decimal  @default(0)
  basementFloorHeight             Decimal  @default(0)
  sitePerimeter                   Decimal  @default(0)
  gateCount                       Int      @default(0)
  formalGateCount                 Int      @default(0)
  temporaryGateCount              Int      @default(0)
  temporaryFacilityArea           Decimal  @default(0)
  siteLevelingArea                Decimal  @default(0)
  landscapeArea                   Decimal  @default(0)
  hardscapeArea                   Decimal  @default(0)
  softscapeArea                   Decimal  @default(0)
  greenArea                       Decimal  @default(0)
  waterFeatureArea                Decimal  @default(0)
  childrenActivityArea            Decimal  @default(0)
  elevatedFloorLandscapeArea      Decimal  @default(0)
  roadArea                        Decimal  @default(0)
  fireRoadArea                    Decimal  @default(0)
  asphaltRoadArea                 Decimal  @default(0)
  standardFloorArea               Decimal  @default(0)
  basementParkingArea             Decimal  @default(0)
  mainBuildingUndergroundArea     Decimal  @default(0)
  civilDefenseArea                Decimal  @default(0)
  nonCivilDefenseArea             Decimal  @default(0)
  publicArea                      Decimal  @default(0)
  lobbyArea                       Decimal  @default(0)
  salesOfficeArea                 Decimal  @default(0)
  showFlatArea                    Decimal  @default(0)
  propertyManagementArea          Decimal  @default(0)
  communityServiceArea            Decimal  @default(0)
  baseArea                        Decimal  @default(0)
  pileFoundationArea              Decimal  @default(0)
  earthworkVolume                 Decimal  @default(0)
  waterproofArea                  Decimal  @default(0)
  roofArea                        Decimal  @default(0)
  insulationArea                  Decimal  @default(0)
  facadeArea                      Decimal  @default(0)
  windowArea                      Decimal  @default(0)
  railingLength                   Decimal  @default(0)
  powerRoomCount                  Int      @default(0)
  pumpRoomCount                   Int      @default(0)
  firePoolVolume                  Decimal  @default(0)
  isPrefabricated                 Boolean  @default(false)
  prefabricatedScope              String?
  prefabricationRate              Decimal  @default(0)
  prefabricatedSystem             String?
  residentialPublicFitoutStandard String   @default("标准")
  undergroundLobbyFitoutStandard  String   @default("标准")
  residentialFitoutDelivery       Boolean  @default(false)
  residentialFitoutType           String   @default("硬装")
  residentialFitoutStandard       String   @default("毛坯")
  facadeStandard                  String   @default("标准")
  windowSystemStandard            String   @default("断桥铝/普通中空")
  elevatorStandard                String   @default("标准")
  smartSystemStandard             String   @default("标准")
  lobbyFitoutStandard             String   @default("标准")
  publicAreaFitoutScope           String?
  commercialPublicFitout          Boolean  @default(false)
  commercialPublicFitoutStandard  String   @default("标准")
  shopDeliveryStandard            String   @default("毛坯")
  basementQualityUpgrade          Boolean  @default(false)
  basementQualityStandard         String   @default("基础美化")
  basementFlooringType            String   @default("金刚砂")
  landscapeStandard               String   @default("标准")
  propertyFitout                  Boolean  @default(true)
  communityFitout                 Boolean  @default(true)
  supportFitout                   Boolean  @default(false)
  hasSalesOffice                  Boolean  @default(true)
  salesOfficeFitoutType           String   @default("硬装+软装")
  hasShowFlat                     Boolean  @default(true)
  showFlatFitoutType              String   @default("全部")
  heatingEnabled                  Boolean  @default(false)
  heatingScope                    String?
  heatingType                     String?
  remark                          String?
  versions                        ProjectVersion[]
  metricValues                    ProjectMetricValue[]
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @default(now()) @updatedAt

  @@index([sourceTemplateId])
}

model ProjectVersion {
  id                     String        @id @default(cuid())
  projectId              String
  project                Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name                   String
  stage                  String?
  status                 String        @default("draft")
  products               ProductType[]
  costRules              ProjectCostRule[]
  costs                  CostLine[]
  revenues               RevenueLine[]
  commercialRevenueLines CommercialRevenueLine[]
  otherRevenueLines      OtherRevenueLine[]
  salesSchedulePlans     SalesSchedulePlan[]
  taxes                  TaxParameter?
  importBatches          ImportBatch[]
  metricValues           ProjectMetricValue[]
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @default(now()) @updatedAt
}

model ProductType {
  id                     String             @id @default(cuid())
  projectVersionId       String
  projectVersion         ProjectVersion     @relation(fields: [projectVersionId], references: [id], onDelete: Cascade)
  productTypeKey         String?
  productTypePreset      ProductTypePreset? @relation(fields: [productTypeKey], references: [key], onDelete: SetNull)
  category               String?
  name                   String
  buildingArea           Decimal @default(0)
  aboveGroundArea        Decimal @default(0)
  undergroundArea        Decimal @default(0)
  saleableArea           Decimal @default(0)
  capacityArea           Decimal @default(0)
  nonSaleableArea        Decimal @default(0)
  baseArea               Decimal @default(0)
  householdCount         Int     @default(0)
  unitCount              Int     @default(0)
  buildingCount          Int     @default(0)
  parkingCount           Int     @default(0)
  salePrice              Decimal @default(0)
  isSaleable             Boolean @default(true)
  participateAllocation  Boolean @default(true)
  allocationWeight       Decimal @default(1)
  remark                 String?
  isActive               Boolean @default(true)
  disabledAt             DateTime?
  costs                  CostLine[]
  revenues               RevenueLine[]
  commercialRevenueLines CommercialRevenueLine[]
  metricValues           ProjectMetricValue[]
  createdAt              DateTime @default(now())
  updatedAt              DateTime @default(now()) @updatedAt

  @@index([projectVersionId])
  @@index([projectVersionId, isActive])
  @@index([productTypeKey])
  @@index([category])
}

model ProjectCostRule {
  id               String @id @default(cuid())
  projectVersionId String
  projectVersion   ProjectVersion @relation(fields: [projectVersionId], references: [id], onDelete: Cascade)
  costCode         String?
  category         String?
  subjectName      String
  sourceTable      String?
  measureBasis     String?
  unit             String?
  defaultTaxRate   Decimal @default(0.09)
  allocationMethod String?
  sortOrder        Int @default(0)
  remark           String?

  @@index([projectVersionId])
}

model CostLine {
  id               String @id @default(cuid())
