generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// First-stage target cost MVP schema rebuilt from the V60 Excel master logic.
// Scope: project initialization, template copy, estimate versions, product types,
// subject trees, detail calculation lines, revenue, tax, summary, Excel mapping,
// version operations, and calculation checks.

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  role         String   @default("admin")
  templates    Template[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id                    String   @id @default(cuid())
  projectName           String
  country               String?
  province              String?
  city                  String?
  district              String?
  marketArea            String?
  projectType           String
  developmentMode       String
  landAcquisitionMethod String?
  landPrice             Decimal  @default(0)
  developerEntity       String?
  partner               String?
  operatorEntity        String?
  projectStatus         String   @default("draft")
  regionId              String?
  region                RegionParameter? @relation(fields: [regionId], references: [id], onDelete: SetNull)
  createdBy             String?
  updatedBy             String?
  remark                String?

  initializations       ProjectInitialization[]
  templates             Template[]
  estimateVersions      EstimateVersion[]
  productTypes          ProductType[]
  overviewIndicators    ProjectOverviewIndicator[]
  productTypeIndicators ProductTypeIndicator[]
  quantityIndicators    QuantityIndicator[]
  buildingStandards     BuildingStandard[]
  quantityRules         QuantityRule[]
  priceTaxRules         PriceTaxRule[]
  allocationRules       AllocationRule[]
  estimateDetailLines   EstimateDetailLine[]
  revenueEstimates      RevenueEstimate[]
  taxEstimates          TaxEstimate[]
  targetCostSummaries   TargetCostSummary[]
  costDashboards        ProjectCostDashboard[]
  versionOperations     VersionOperation[]
  calculationChecks     CalculationCheck[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([regionId])
  @@index([projectType])
  @@index([developmentMode])
  @@index([projectStatus])
}

model ProjectInitialization {
  id                       String   @id @default(cuid())
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectType              String
  developmentMode          String
  regionId                 String?
  region                   RegionParameter? @relation(fields: [regionId], references: [id], onDelete: SetNull)
  estimateStage            String
  precisionLevel           String
  selectedTemplateId       String?
  selectedTemplate         Template? @relation("SelectedTemplate", fields: [selectedTemplateId], references: [id], onDelete: SetNull)
  projectTemplateId        String?
  projectTemplate          Template? @relation("ProjectTemplate", fields: [projectTemplateId], references: [id], onDelete: SetNull)
  selectedProductTypes     String?
  enabledSpecialOptions    String?
  initializationStatus     String   @default("draft")
  initializedBy            String?
  initializedAt            DateTime?
  baseTemplateVersion      String?
  costDictionaryVersion    String?
  regionParameterVersion   String?
  createdBy                String?
  updatedBy                String?
  remark                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([projectId])
  @@index([regionId])
  @@index([selectedTemplateId])
  @@index([projectTemplateId])
  @@index([initializationStatus])
}

model Template {
  id                   String   @id @default(cuid())
  templateName         String
  templateType         String   @default("system")
  templateSource       String   @default("system")
  baseTemplateId       String?
  baseTemplate         Template?  @relation("TemplateToTemplate", fields: [baseTemplateId], references: [id], onDelete: SetNull)
  derivedTemplates     Template[] @relation("TemplateToTemplate")
  projectId            String?
  project              Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ownerUserId          String?
  owner                User?     @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  ownerCompanyId       String?
  templateVersion      String   @default("v1")
  applicableProjectType String?
  applicableStage      String?
  isSystemTemplate     Boolean  @default(false)
  isProjectTemplate    Boolean  @default(false)
  isPersonalTemplate   Boolean  @default(false)
  isCompanyTemplate    Boolean  @default(false)
  isPublic             Boolean  @default(false)
  isEnabled            Boolean  @default(true)
  lockedStatus         String   @default("unlocked")
  changeReason         String?
  createdBy            String?
  updatedBy            String?
  remark               String?

  selectedInInitializations ProjectInitialization[] @relation("SelectedTemplate")
  projectTemplateInitializations ProjectInitialization[] @relation("ProjectTemplate")
  estimateVersions     EstimateVersion[]
  costSubjects         CostSubject[]

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([projectId])
  @@index([ownerUserId])
  @@index([baseTemplateId])
  @@index([templateType])
  @@index([templateSource])
  @@index([applicableProjectType])
}

model EstimateVersion {
  id                                String   @id @default(cuid())
  projectId                         String
  project                           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectTemplateId                 String?
  projectTemplate                   Template? @relation(fields: [projectTemplateId], references: [id], onDelete: SetNull)
  versionName                       String
  versionType                       String
  versionNo                         String?
  baseVersionId                     String?
  baseVersion                       EstimateVersion? @relation("EstimateVersionToEstimateVersion", fields: [baseVersionId], references: [id], onDelete: SetNull)
  derivedVersions                   EstimateVersion[] @relation("EstimateVersionToEstimateVersion")
  precisionLevel                    String?
  excelTemplateVersion              String?
  costDictionaryVersion             String?
  regionParameterVersion            String?
  ruleVersion                       String?
  allocationRuleVersion             String?
  taxRuleVersion                    String?
  priceVersion                      String?
  indicatorVersion                  String?
  versionStatus                     String   @default("draft")
  isLocked                          Boolean  @default(false)
  lockedBy                          String?
  lockedAt                          DateTime?
  changeReason                      String?
  versionRemark                     String?
  createdBy                         String?
  updatedBy                         String?
  remark                            String?

  productTypes                      ProductType[]
  projectOverviewIndicator          ProjectOverviewIndicator?
  productTypeIndicators             ProductTypeIndicator[]
  quantityIndicators                QuantityIndicator[]
  buildingStandards                 BuildingStandard[]
  quantityRules                     QuantityRule[]
  priceTaxRules                     PriceTaxRule[]
  allocationRules                   AllocationRule[]
  estimateDetailLines               EstimateDetailLine[]
  revenueEstimates                  RevenueEstimate[]
  taxEstimates                      TaxEstimate[]
  targetCostSummaries               TargetCostSummary[]
  projectCostDashboard              ProjectCostDashboard?
  versionOperations                 VersionOperation[] @relation("VersionOperationMainVersion")
  comparedVersionOperations         VersionOperation[] @relation("VersionOperationComparedVersion")
  calculationChecks                 CalculationCheck[]

  createdAt                         DateTime @default(now())
  updatedAt                         DateTime @updatedAt

  @@index([projectId])
  @@index([projectTemplateId])
  @@index([baseVersionId])
  @@index([versionType])
  @@index([versionStatus])
  @@index([isLocked])
}

model ProductType {
  id                       String   @id @default(cuid())
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId                String
  version                  EstimateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  productTypeCode          String
  productTypeName          String
  productCategory          String?
  isSaleable               Boolean  @default(false)
  isCostObject             Boolean  @default(true)
  isTaxClearanceObject     Boolean  @default(false)
  isEnabled                Boolean  @default(true)
  defaultAllocationWeight  Decimal  @default(1)
  defaultIncomeTaxObject   String?
  defaultLandVatObject     String?
  sortOrder                Int      @default(0)
  createdBy                String?
  updatedBy                String?
  remark                   String?

  productTypeIndicators    ProductTypeIndicator[]
  quantityIndicators       QuantityIndicator[]
  buildingStandards        BuildingStandard[]
  priceTaxRules            PriceTaxRule[]
  allocationRulesAsProductType AllocationRule[] @relation("AllocationRuleProductType")
  allocationRulesAsCostObject  AllocationRule[] @relation("AllocationRuleCostObject")
  estimateLinesAsProductType   EstimateDetailLine[] @relation("EstimateLineProductType")
  estimateLinesAsCostObject    EstimateDetailLine[] @relation("EstimateLineCostObject")
  revenueEstimates         RevenueEstimate[]
  targetCostSummaries      TargetCostSummary[]

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@unique([versionId, productTypeCode])
  @@index([projectId])
  @@index([versionId])
  @@index([productCategory])
  @@index([isEnabled])
}

model ProjectOverviewIndicator {
  id                       String   @id @default(cuid())
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId                String   @unique
  version                  EstimateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  landArea                 Decimal  @default(0)
  capacityArea             Decimal  @default(0)
  totalBuildingArea        Decimal  @default(0)
  aboveGroundArea          Decimal  @default(0)
  undergroundArea          Decimal  @default(0)
  saleableArea             Decimal  @default(0)
  parkingCount             Decimal  @default(0)
  chargingPileCount        Decimal  @default(0)
  householdCount           Decimal  @default(0)
  buildingCount            Decimal  @default(0)
  unitCount                Decimal  @default(0)
  sitePerimeter            Decimal  @default(0)
  gateCount                Decimal  @default(0)
  landscapeArea            Decimal  @default(0)
  hardscapeArea            Decimal  @default(0)
  softscapeArea            Decimal  @default(0)
  civilDefenseArea         Decimal  @default(0)
  heatingArea              Decimal  @default(0)
  prefabricatedArea        Decimal  @default(0)
  antiqueBuildingArea      Decimal  @default(0)
  createdBy                String?
  updatedBy                String?
  remark                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([projectId])
}

model ProductTypeIndicator {
  id                       String   @id @default(cuid())
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId                String
  version                  EstimateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  productTypeId            String
  productType              ProductType @relation(fields: [productTypeId], references: [id], onDelete: Cascade)
  buildingArea             Decimal  @default(0)
  saleableArea             Decimal  @default(0)
  capacityArea             Decimal  @default(0)
  landOccupationArea       Decimal  @default(0)
  aboveGroundArea          Decimal  @default(0)
  undergroundArea          Decimal  @default(0)
  buildingCount            Decimal  @default(0)
  unitCount                Decimal  @default(0)
  floorCount               Decimal  @default(0)
  householdCount           Decimal  @default(0)
  parkingCount             Decimal  @default(0)
  supportArea              Decimal  @default(0)
  createdBy                String?
  updatedBy                String?
  remark                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@unique([versionId, productTypeId])
  @@index([projectId])
  @@index([productTypeId])
}

model QuantityIndicator {
  id                       String   @id @default(cuid())
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId                String
  version                  EstimateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  productTypeId            String?
  productType              ProductType? @relation(fields: [productTypeId], references: [id], onDelete: SetNull)
  indicatorName            String
  indicatorSource          String
  indicatorValue           Decimal  @default(0)
  indicatorUnit            String?
  isSystemCalculated       Boolean  @default(false)
  calculationRemark        String?
  createdBy                String?
  updatedBy                String?
  remark                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([projectId])
  @@index([versionId])
  @@index([productTypeId])
  @@index([indicatorName])
}

model BuildingStandard {
  id                       String   @id @default(cuid())
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId                String
  version                  EstimateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  productTypeId            String?
  productType              ProductType? @relation(fields: [productTypeId], references: [id], onDelete: SetNull)
  deliveryStandard         String?
  facadeStandard           String?
  windowDoorStandard       String?
  landscapeStandard        String?
  garageStandard           String?
  intelligentStandard      String?
  isFineDecoration         Boolean  @default(false)
  isCivilDefense           Boolean  @default(false)
  isHeating                Boolean  @default(false)
  isPrefabricated          Boolean  @default(false)
  isAntiqueBuilding        Boolean  @default(false)
  createdBy                String?
  updatedBy                String?
  remark                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([projectId])
  @@index([versionId])
  @@index([productTypeId])
}

model CostSubject {
  id                       String   @id @default(cuid())
  templateId               String?
  template                 Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  parentId                 String?
  parent                   CostSubject? @relation("CostSubjectTree", fields: [parentId], references: [id], onDelete: SetNull)
  children                 CostSubject[] @relation("CostSubjectTree")
  subjectCode              String
  subjectName              String
  subjectLevel             Int
  subjectFullPath          String?
  isLeaf                   Boolean  @default(false)
  isEnabled                Boolean  @default(true)
  isConditionalSubject     Boolean  @default(false)
  sortOrder                Int      @default(0)
  excelSourceSheet         String?
  excelSourceRow           Int?
  excelSourceColumn        Int?
  excelMasterVersion       String?
  createdBy                String?
  updatedBy                String?
  remark                   String?

  detailSubjects           DetailSubject[]
  estimateDetailLines      EstimateDetailLine[]
  targetCostSummaries      TargetCostSummary[]

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([templateId])
  @@index([parentId])
  @@index([subjectCode])
  @@index([subjectLevel])
  @@index([isLeaf])
}

model DetailSubject {
  id                          String   @id @default(cuid())
  costSubjectId               String
  costSubject                 CostSubject @relation(fields: [costSubjectId], references: [id], onDelete: Cascade)
  detailSubjectCode           String?
  detailSubjectName           String
  subjectFullPath             String?
  measurementBasis            String?
  defaultIndicatorSource      String?
  defaultQuantityUnit         String?
  defaultPricingUnit          String?
  defaultTaxRate              Decimal  @default(0)
  defaultProductType          String?
  defaultCostObject           String?
  participateAllocation       Boolean  @default(false)
  defaultAllocationBasis      String?
  enterLandVatDeduction       Boolean  @default(false)
  enterIncomeTaxCost          Boolean  @default(true)
  createdBy                   String?
  updatedBy                   String?
  remark                      String?

  quantityRules               QuantityRule[]
  priceTaxRules               PriceTaxRule[]
  allocationRules             AllocationRule[]
  estimateDetailLines         EstimateDetailLine[]

  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@index([costSubjectId])
  @@index([detailSubjectCode])
  @@index([detailSubjectName])
}

model QuantityRule {
  id                       String   @id @default(cuid())
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId                String
  version                  EstimateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  detailSubjectId          String
  detailSubject            DetailSubject @relation(fields: [detailSubjectId], references: [id], onDelete: Cascade)
  indicatorName            String
  indicatorSource          String?
  indicatorValue           Decimal  @default(0)
  contentRatio             Decimal  @default(1)
  contentUnit              String?
  quantityFormula          String?
  engineeringQuantity      Decimal  @default(0)
  quantityUnit             String?
  allowManualAdjustment    Boolean  @default(true)
  calculationRemark        String?
  createdBy                String?
  updatedBy                String?
  remark                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([projectId])
  @@index([versionId])
  @@index([detailSubjectId])
  @@index([indicatorName])
}

model UnitDictionary {
  id                       String   @id @default(cuid())
  unitType                 String
  unitName                 String
  unitDescription          String?
  isEnabled                Boolean  @default(true)
  sortOrder                Int      @default(0)
  createdBy                String?
  updatedBy                String?
  remark                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@unique([unitType, unitName])
  @@index([unitType])
  @@index([isEnabled])
}

model PriceTaxRule {
  id                       String   @id @default(cuid())
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId                String
  version                  EstimateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  detailSubjectId          String
  detailSubject            DetailSubject @relation(fields: [detailSubjectId], references: [id], onDelete: Cascade)
  productTypeId            String?
  productType              ProductType? @relation(fields: [productTypeId], references: [id], onDelete: SetNull)
  unitPriceTaxIncluded     Decimal  @default(0)
  unitPriceTaxExcluded     Decimal  @default(0)
  taxRate                  Decimal  @default(0)
  priceType                String?
  priceSource              String?
  priceRemark              String?
  allowOverride            Boolean  @default(true)
  createdBy                String?
  updatedBy                String?
  remark                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([projectId])
  @@index([versionId])
  @@index([detailSubjectId])
  @@index([productTypeId])
}

model AllocationRule {
  id                       String   @id @default(cuid())
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId                String
  version                  EstimateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  detailSubjectId          String
  detailSubject            DetailSubject @relation(fields: [detailSubjectId], references: [id], onDelete: Cascade)
  isDirectAttribution      Boolean  @default(false)
  productTypeId            String?
  productType              ProductType? @relation("AllocationRuleProductType", fields: [productTypeId], references: [id], onDelete: SetNull)
  costObjectId             String?
  costObject               ProductType? @relation("AllocationRuleCostObject", fields: [costObjectId], references: [id], onDelete: SetNull)
  participateAllocation    Boolean  @default(false)
  allocationBasis          String?
  allocationObjectScope    String?
  allocationRatio          Decimal  @default(0)
  allowManualAdjustment    Boolean  @default(true)
  allocationRemark         String?
  createdBy                String?
  updatedBy                String?
  remark                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([projectId])
  @@index([versionId])
  @@index([detailSubjectId])
  @@index([productTypeId])
  @@index([costObjectId])
}

model EstimateDetailLine {
  id                       String   @id @default(cuid())
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId                String
  version                  EstimateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  productTypeId            String?
  productType              ProductType? @relation("EstimateLineProductType", fields: [productTypeId], references: [id], onDelete: SetNull)
  costObjectId             String?
  costObject               ProductType? @relation("EstimateLineCostObject", fields: [costObjectId], references: [id], onDelete: SetNull)
  costSubjectId            String
  costSubject              CostSubject @relation(fields: [costSubjectId], references: [id], onDelete: Restrict)
  detailSubjectId          String
  detailSubject            DetailSubject @relation(fields: [detailSubjectId], references: [id], onDelete: Restrict)
  targetCostSummaryId      String?
  targetCostSummary        TargetCostSummary? @relation(fields: [targetCostSummaryId], references: [id], onDelete: SetNull)
  measurementBasis         String?
  indicatorSource          String?
  indicatorValue           Decimal  @default(0)
  contentRatio             Decimal  @default(1)
  engineeringQuantity      Decimal  @default(0)
  quantityUnit             String?
  pricingUnit              String?
  unitPriceTaxIncluded     Decimal  @default(0)
  unitPriceTaxExcluded     Decimal  @default(0)
  taxRate                  Decimal  @default(0)
  amountTaxIncluded        Decimal  @default(0)
  amountTaxExcluded        Decimal  @default(0)
  taxAmount                Decimal  @default(0)
  priceSource              String?
  participateAllocation    Boolean  @default(false)
  allocatedAmount          Decimal  @default(0)
  calculationRemark        String?
  sortOrder                Int      @default(0)
  createdBy                String?
  updatedBy                String?
  remark                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([projectId])
  @@index([versionId])
  @@index([productTypeId])
  @@index([costObjectId])
  @@index([costSubjectId])
  @@index([detailSubjectId])
  @@index([targetCostSummaryId])
}

model RevenueEstimate {
  id                       String   @id @default(cuid())
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId                String
  version                  EstimateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  productTypeId            String
  productType              ProductType @relation(fields: [productTypeId], references: [id], onDelete: Restrict)
  revenueType              String
  measurementQuantity      Decimal  @default(0)
  measurementUnit          String?
  saleUnitPrice            Decimal  @default(0)
  pricingUnit              String?
  revenueTaxIncluded       Decimal  @default(0)
  revenueTaxExcluded       Decimal  @default(0)
  outputTaxRate            Decimal  @default(0)
  outputTaxAmount          Decimal  @default(0)
  sellThroughPeriod        String?
  collectionPlan           String?
  createdBy                String?
  updatedBy                String?
  remark                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([projectId])
  @@index([versionId])
  @@index([productTypeId])
  @@index([revenueType])
}

model TaxEstimate {
  id                       String   @id @default(cuid())
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId                String
  version                  EstimateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  taxType                  String
  taxBase                  Decimal  @default(0)
  taxRate                  Decimal  @default(0)
  deductibleInputTax       Decimal  @default(0)
  outputTax                Decimal  @default(0)
  payableVat               Decimal  @default(0)
  surtaxAmount             Decimal  @default(0)
  landVatDeductibleCost    Decimal  @default(0)
  landVatAmount            Decimal  @default(0)
  incomeTaxPreTaxProfit    Decimal  @default(0)
  incomeTaxAmount          Decimal  @default(0)
  taxRemark                String?
  createdBy                String?
  updatedBy                String?
  remark                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([projectId])
  @@index([versionId])
  @@index([taxType])
}

model TargetCostSummary {
  id                       String   @id @default(cuid())
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId                String
  version                  EstimateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  costSubjectId            String
  costSubject              CostSubject @relation(fields: [costSubjectId], references: [id], onDelete: Restrict)
  subjectLevel             Int
  productTypeId            String?
  productType              ProductType? @relation(fields: [productTypeId], references: [id], onDelete: SetNull)
  totalAmountTaxIncluded   Decimal  @default(0)
  totalAmountTaxExcluded   Decimal  @default(0)
  totalTaxAmount           Decimal  @default(0)
  buildingUnitCost         Decimal  @default(0)
  saleableUnitCost         Decimal  @default(0)
  beforeAllocationAmount   Decimal  @default(0)
  afterAllocationAmount    Decimal  @default(0)
  summarizedAt             DateTime?
  createdBy                String?
  updatedBy                String?
  remark                   String?

  estimateDetailLines      EstimateDetailLine[]

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([projectId])
  @@index([versionId])
  @@index([costSubjectId])
  @@index([productTypeId])
  @@index([subjectLevel])
}

model ProjectCostDashboard {
  id                       String   @id @default(cuid())
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId                String   @unique
  version                  EstimateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  salesRevenue             Decimal  @default(0)
  otherRevenue             Decimal  @default(0)
  developmentCostTaxIncluded Decimal @default(0)
  developmentCostTaxExcluded Decimal @default(0)
  totalTaxAmount           Decimal  @default(0)
  preTaxOperatingProfit    Decimal  @default(0)
  incomeTax                Decimal  @default(0)
  netProfitAfterTax        Decimal  @default(0)
  preTaxSalesProfitRate    Decimal  @default(0)
  netSalesProfitRate       Decimal  @default(0)
  buildingUnitCost         Decimal  @default(0)
  saleableUnitCost         Decimal  @default(0)
  calculatedAt             DateTime?
  createdBy                String?
  updatedBy                String?
  remark                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([projectId])
}

model ExcelMapping {
  id                       String   @id @default(cuid())
  excelFileName            String
  excelFileVersion         String?
  sheetName                String
  excelRow                 Int?
  excelColumn              Int?
  excelFieldName           String?
  excelSubjectCode         String?
  excelSubjectName         String?
  excelFormula             String?
  excelUnit                String?
  excelTaxRate             String?
  excelAllocationBasis     String?
  systemModule             String
  systemField              String
  mappingStatus            String   @default("pending")
  importBatch              String?
  createdBy                String?
  updatedBy                String?
  remark                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([excelFileVersion])
  @@index([sheetName])
  @@index([excelSubjectCode])
  @@index([systemModule])
  @@index([mappingStatus])
}

model VersionOperation {
  id                       String   @id @default(cuid())
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId                String
  version                  EstimateVersion @relation("VersionOperationMainVersion", fields: [versionId], references: [id], onDelete: Cascade)
  compareVersionId         String?
  compareVersion           EstimateVersion? @relation("VersionOperationComparedVersion", fields: [compareVersionId], references: [id], onDelete: SetNull)
  operationType            String
  beforeStatus             String?
  afterStatus              String?
  operatedBy               String?
  operatedAt               DateTime @default(now())
  operationReason          String?
  differenceAmount         Decimal  @default(0)
  differenceRemark         String?
  createdBy                String?
  updatedBy                String?
  remark                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([projectId])
  @@index([versionId])
  @@index([compareVersionId])
  @@index([operationType])
}

model CalculationCheck {
  id                       String   @id @default(cuid())
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versionId                String
  version                  EstimateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  checkObjectType          String
  checkObjectId            String?
  checkRule                String
  checkLevel               String   @default("warning")
  checkResult              String   @default("pending")
  errorMessage             String?
  isProcessed              Boolean  @default(false)
  processedBy              String?
  processedAt              DateTime?
  createdBy                String?
  updatedBy                String?
  remark                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([projectId])
  @@index([versionId])
  @@index([checkObjectType])
  @@index([checkLevel])
  @@index([checkResult])
  @@index([isProcessed])
}

model RegionParameter {
  id                       String   @id @default(cuid())
  country                  String?
  province                 String?
  city                     String?
  district                 String?
  marketArea               String?
  defaultVatRate           Decimal  @default(0)
  defaultSurtaxRate        Decimal  @default(0)
  defaultIncomeTaxRate     Decimal  @default(0)
  landVatPrepayRate        Decimal  @default(0)
  regionParameterVersion   String   @default("v1")
  effectiveDate            DateTime?
  expiryDate               DateTime?
  dataSource               String?
  confidenceLevel          String?
  approvedBy               String?
  approvedAt               DateTime?
  createdBy                String?
  updatedBy                String?
  remark                   String?

  projects                 Project[]
  initializations          ProjectInitialization[]

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([country])
  @@index([province])
  @@index([city])
  @@index([district])
  @@index([regionParameterVersion])
}

model DictionaryItem {
  id                       String   @id @default(cuid())
  dictionaryType           String
  dictionaryCode           String
  dictionaryName           String
  defaultPrecisionLevel    String?
  defaultSubjectDepth      String?
  isEnabled                Boolean  @default(true)
  sortOrder                Int      @default(0)
  createdBy                String?
  updatedBy                String?
  remark                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@unique([dictionaryType, dictionaryCode])
  @@index([dictionaryType])
  @@index([isEnabled])
}
